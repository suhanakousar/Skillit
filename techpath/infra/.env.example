# PostgreSQL
POSTGRES_USER=techpath
POSTGRES_PASSWORD=techpath
POSTGRES_DB=techpath

# Backend
DATABASE_URL=postgresql+asyncpg://techpath:techpath@postgres:5432/techpath
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-a-long-random-secret
ENVIRONMENT=development

# Auto-bootstrap on startup: creates tables + seeds starter content
# if the DB is empty. Set to false in production if you run alembic manually.
AUTO_BOOTSTRAP=true

# Demo user (one-click login). Disable in production.
SEED_DEMO_USER=true
DEMO_EMAIL=demo@techpath.dev
DEMO_PASSWORD=techpath123

# Code execution — Judge0 is optional. Without it, the backend falls back
# to an in-process Python runner (safe enough for dev; never for untrusted prod).
JUDGE0_URL=http://judge0:2358
JUDGE0_API_KEY=
USE_LOCAL_RUNNER_FALLBACK=true

# Claude API (optional — AI routes return stub content without it)
ANTHROPIC_API_KEY=

# Frontend
VITE_API_URL=http://localhost:8000
